# Server
PORT=5000
NODE_ENV=development
SERVER_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Database (MongoDB Atlas)
DB_URI=mongodb+srv://username:password@cluster.mongodb.net/your-project
# Optional: helps if local/ISP DNS breaks MongoDB SRV lookups
DNS_SERVERS=8.8.8.8,1.1.1.1

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email (Brevo)
BREVO_API_KEY=xkeysib-your_api_key_here
BREVO_FROM_EMAIL=noreply@yourdomain.com
BREVO_FROM_NAME=Company_Name

# Stripe Payments (Optional)
STRIPE_SECRET_KEY=sk_test_your_key

# Upstash Workflows (Optional)
QSTASH_URL=https://qstash.upstash.io/v1
QSTASH_TOKEN=your_token

# Arcjet Security (Optional)
ARCJET_KEY=your_key
